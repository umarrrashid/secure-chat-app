<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>US Chat</title>

    <link rel="stylesheet" href="/style.css">

    <script src="/socket.io/socket.io.js"></script>

</head>

<body>

<div class="chat-container">

    <!-- ================= HEADER ================= -->

    <div class="chat-header">

        <h1>

            Chat with <%= chattingWith %>

        </h1>

        <div class="top-buttons">

            <a href="/users">

                <button class="clear-btn">

                    Back

                </button>

            </a>

        </div>

    </div>



    <!-- ================= CHAT BOX ================= -->

    <div class="chat-box" id="chat-box">

        <% messages.forEach((msg) => { %>

            <div class="message <%= msg.sender === user ? 'my-message' : 'other-message' %>">

                <div class="message-top">

                    <strong>

                        <%= msg.sender %>

                    </strong>

                    <span class="time">

                        <%= msg.time %>

                    </span>

                </div>



                <!-- FILES -->

                <% if(msg.file){ %>

                    <% if(msg.file.match(/\.(jpg|jpeg|png|gif|webp)$/i)){ %>

                        <img
                            src="<%= msg.file %>"
                            class="chat-image"
                        >

                    <% } else { %>

                        <a
                            href="<%= msg.file %>"
                            target="_blank"
                            class="file-link"
                        >

                            📎 <%= msg.file.split('/').pop() %>

                        </a>

                    <% } %>

                <% } %>



                <!-- TEXT -->

                <% if(msg.text){ %>

                    <div class="message-text">

                        <%= msg.text %>

                    </div>

                <% } %>

            </div>

        <% }) %>

    </div>



    <!-- ================= BOTTOM BAR ================= -->

    <div class="bottom-bar">

        <!-- MESSAGE FORM -->

        <form id="chat-form" class="message-form">

            <input
                type="text"
                id="message-input"
                placeholder="Type message..."
                autocomplete="off"
                required
            >

            <button type="submit" class="send-btn">

                Send

            </button>

        </form>



        <!-- UPLOAD BUTTON -->

        <button id="open-upload" class="upload-toggle-btn">

            📎

        </button>

    </div>



    <!-- ================= HIDDEN UPLOAD ================= -->

    <div id="upload-section" class="upload-section hidden-upload">

        <form
            action="/upload/<%= chattingWith %>"
            method="POST"
            enctype="multipart/form-data"
            class="upload-form"
        >

            <label for="file-input" class="attach-btn">

                Choose File

            </label>



            <input
                type="file"
                name="file"
                id="file-input"
                required
            >



            <span id="file-name">

                No file selected

            </span>



            <button type="submit" class="upload-btn">

                Upload

            </button>

        </form>

    </div>

</div>



<!-- ================= SOCKET SCRIPT ================= -->

<script>

    const socket = io();

    const form = document.getElementById("chat-form");

    const input = document.getElementById("message-input");

    const chatBox = document.getElementById("chat-box");



    const currentUser = "<%= user %>";

    const ROOM_ID = "<%= room %>";



    socket.emit("join room", ROOM_ID);



    // ================= SEND MESSAGE =================

    form.addEventListener("submit", (e) => {

        e.preventDefault();



        if(input.value.trim() === ""){

            return;

        }



        socket.emit("chat message", {

            room: ROOM_ID,

            user: currentUser,

            message: input.value

        });



        input.value = "";

    });



    // ================= RECEIVE MESSAGE =================

    socket.on("chat message", (data) => {

        const div = document.createElement("div");



        div.classList.add("message");



        if(data.user === currentUser){

            div.classList.add("my-message");

        }

        else{

            div.classList.add("other-message");

        }



        div.innerHTML = `

            <div class="message-top">

                <strong>

                    ${data.user}

                </strong>

                <span class="time">

                    ${data.time}

                </span>

            </div>

            <div class="message-text">

                ${data.message}

            </div>

        `;



        chatBox.appendChild(div);

        chatBox.scrollTop = chatBox.scrollHeight;

    });



    // ================= AUTO SCROLL =================

    chatBox.scrollTop = chatBox.scrollHeight;



    // ================= UPLOAD TOGGLE =================

    const openUpload = document.getElementById("open-upload");

    const uploadSection = document.getElementById("upload-section");

    const fileInput = document.getElementById("file-input");

    const fileName = document.getElementById("file-name");



    openUpload.addEventListener("click", () => {

        uploadSection.classList.toggle("hidden-upload");

    });



    fileInput.addEventListener("change", () => {

        if(fileInput.files.length > 0){

            fileName.textContent = fileInput.files[0].name;

        }

    });

</script>

</body>

</html>