<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">

    <meta name="viewport"
    content="width=device-width, initial-scale=1.0">

    <title>US Chat</title>

    <link rel="stylesheet" href="/style.css">

    <script src="/socket.io/socket.io.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>

</head>

<body>

<div class="chat-container">

    <div class="top-bar">

        <h1>US Chat</h1>

        <div class="buttons">

            <a href="/logout">
                <button class="logout-btn">
                    Logout
                </button>
            </a>

            <a href="/clear-chat">
                <button class="clear-btn">
                    Clear
                </button>
            </a>

        </div>

    </div>

    <div class="chat-box" id="chat-box">

        <% messages.forEach(msg => { %>

            <script>

                const bytes = CryptoJS.AES.decrypt(
                    "<%= msg.text %>",
                    "mysecretkey"
                );

                const decrypted =
                bytes.toString(CryptoJS.enc.Utf8);

                document.write(`

                    <div class="
                    message
                    <%= msg.sender === user ?
                    'my-message' :
                    'other-message' %>
                    ">

                        <b><%= msg.sender %></b>

                        <p>${decrypted}</p>

                    </div>

                `);

            </script>

        <% }) %>

    </div>

    <form id="chat-form">

        <input
            type="text"
            id="message-input"
            placeholder="Type message..."
            autocomplete="off"
        >

        <button type="submit">
            Send
        </button>

    </form>

</div>

<script>

const socket = io();

const form = document.getElementById("chat-form");

const input = document.getElementById("message-input");

const chatBox = document.getElementById("chat-box");

const USER = "<%= user %>";

const SECRET = "mysecretkey";

form.addEventListener("submit", (e) => {

    e.preventDefault();

    if(input.value.trim() === ""){
        return;
    }

    const encrypted = CryptoJS.AES.encrypt(
        input.value,
        SECRET
    ).toString();

    socket.emit("chat message", {

        user: USER,

        message: encrypted

    });

    input.value = "";

});

socket.on("chat message", (data) => {

    const bytes = CryptoJS.AES.decrypt(
        data.message,
        SECRET
    );

    const decrypted =
    bytes.toString(CryptoJS.enc.Utf8);

    const div = document.createElement("div");

    if(data.user === USER){

        div.classList.add(
            "message",
            "my-message"
        );

    }
    else{

        div.classList.add(
            "message",
            "other-message"
        );

    }

    div.innerHTML = `

        <b>${data.user}</b>

        <p>${decrypted}</p>

    `;

    chatBox.appendChild(div);

    chatBox.scrollTop =
    chatBox.scrollHeight;

});

</script>

</body>
</html>