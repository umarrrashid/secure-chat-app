<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>US Chat</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, Helvetica, sans-serif;
        }

        body{
            height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            background: linear-gradient(135deg,#071b3a,#4b3b8f);
        }

        .chat-container{
            width:850px;
            height:700px;
            background:white;
            border-radius:25px;
            overflow:hidden;
            box-shadow:0 20px 50px rgba(0,0,0,0.4);
            display:flex;
            flex-direction:column;
        }

        .chat-header{
            background:#00153d;
            color:white;
            padding:30px;
            display:flex;
            justify-content:space-between;
            align-items:center;
        }

        .chat-header h1{
            font-size:55px;
        }

        .back-btn{
            text-decoration:none;
            background:#3461ff;
            color:white;
            padding:14px 28px;
            border-radius:15px;
            font-weight:bold;
        }

        .messages{
            flex:1;
            background:#ececec;
            padding:25px;
            overflow-y:auto;
            display:flex;
            flex-direction:column;
            gap:18px;
        }

        .my-message{
            align-self:flex-end;
            background:linear-gradient(135deg,#6a5cff,#4f46e5);
            color:white;
            padding:16px;
            border-radius:18px 18px 5px 18px;
            max-width:320px;
        }

        .other-message{
            align-self:flex-start;
            background:#dbe7f7;
            color:black;
            padding:16px;
            border-radius:18px 18px 18px 5px;
            max-width:320px;
        }

        .msg-top{
            display:flex;
            align-items:center;
            gap:10px;
            margin-bottom:8px;
        }

        .username{
            font-weight:bold;
            font-size:28px;
        }

        .time{
            font-size:14px;
            opacity:0.8;
        }

        .text{
            font-size:24px;
            word-wrap:break-word;
        }

        .chat-form{
            display:flex;
            padding:18px;
            background:white;
            gap:15px;
        }

        .chat-form input{
            flex:1;
            padding:18px;
            border-radius:18px;
            border:2px solid #6a5cff;
            font-size:22px;
            outline:none;
        }

        .chat-form button{
            padding:18px 35px;
            border:none;
            border-radius:18px;
            background:#3461ff;
            color:white;
            font-size:22px;
            font-weight:bold;
            cursor:pointer;
        }

        .chat-form button:hover{
            background:#2347d8;
        }
    </style>
</head>

<body>

<div class="chat-container">

    <div class="chat-header">
        <h1>Chat with <%= friend %></h1>

        <a href="/users" class="back-btn">
            Back
        </a>
    </div>

    <div class="messages">

        <% messages.forEach(msg => { %>

            <% if(msg.sender === currentUser){ %>

                <div class="my-message">

                    <div class="msg-top">
                        <div class="username">
                            <%= msg.sender %>
                        </div>

                        <div class="time">
                            <%= new Date(msg.createdAt).toLocaleTimeString("en-IN", {
                                timeZone: "Asia/Kolkata",
                                hour: "2-digit",
                                minute: "2-digit"
                            }) %>
                        </div>
                    </div>

                    <div class="text">
                        <%= msg.text %>
                    </div>

                </div>

            <% } else { %>

                <div class="other-message">

                    <div class="msg-top">
                        <div class="username">
                            <%= msg.sender %>
                        </div>

                        <div class="time">
                            <%= new Date(msg.createdAt).toLocaleTimeString("en-IN", {
                                timeZone: "Asia/Kolkata",
                                hour: "2-digit",
                                minute: "2-digit"
                            }) %>
                        </div>
                    </div>

                    <div class="text">
                        <%= msg.text %>
                    </div>

                </div>

            <% } %>

        <% }) %>

    </div>

    <form class="chat-form" action="/send-message" method="POST">

        <input type="hidden" name="receiver" value="<%= friend %>">

        <input 
            type="text" 
            name="message" 
            placeholder="Type message..."
            required
        >

        <button type="submit">
            Send
        </button>

    </form>

</div>

</body>
</html>