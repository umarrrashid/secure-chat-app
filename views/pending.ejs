<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Approval Pending</title>

    <style>

        *{

            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;

        }

        body{

            height: 100vh;

            display: flex;

            justify-content: center;

            align-items: center;

            background:
            linear-gradient(
                135deg,
                #0f172a,
                #1e3a5f,
                #4c3f91
            );

        }

        .card{

            width: 420px;

            padding: 40px;

            border-radius: 24px;

            background: rgba(255,255,255,0.08);

            backdrop-filter: blur(14px);

            box-shadow:
            0 10px 30px rgba(0,0,0,0.35);

            text-align: center;

            color: white;

        }

        .icon{

            font-size: 70px;

            margin-bottom: 20px;

        }

        h1{

            font-size: 38px;

            margin-bottom: 15px;

        }

        p{

            color: #d1d5db;

            line-height: 1.6;

            margin-bottom: 30px;

        }

        a{

            display: inline-block;

            padding: 14px 28px;

            border-radius: 12px;

            text-decoration: none;

            color: white;

            background:
            linear-gradient(
                135deg,
                #4f46e5,
                #2563eb
            );

            transition: 0.3s;

            font-weight: bold;

        }

        a:hover{

            transform: scale(1.05);

        }

    </style>

</head>

<body>

    <div class="card">

        <div class="icon">

            ⏳

        </div>

        <h1>

            Approval Pending

        </h1>

        <p>

            Your account has been created successfully.
            Please wait until the admin approves your account.

        </p>

        <a href="/login">

            Back To Login

        </a>

    </div>

</body>

</html>