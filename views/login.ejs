<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Login</title>

    <link rel="stylesheet" href="/style.css">

</head>

<body>



    <div class="login-container">

        <div class="login-card">

            <h1>US Chat</h1>

            <p class="subtitle">
                Secure Realtime Chat App
            </p>



            <form action="/login" method="POST">

                <input
                    type="text"
                    name="username"
                    placeholder="Username"
                    required
                >



                <input
                    type="password"
                    name="password"
                    placeholder="Password"
                    required
                >



                <button type="submit">

                    Login

                </button>

            </form>

        </div>

    </div>



</body>

</html>