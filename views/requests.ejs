<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
    content="width=device-width, initial-scale=1.0">

    <title>Chat Requests</title>

    <link rel="stylesheet" href="/style.css">

</head>

<body class="requests-page">

    <div class="requests-container">

        <div class="requests-card">

            <div class="requests-header">

                <h1>Chat Requests</h1>

                <a href="/users">

                    <button class="back-btn">

                        Back

                    </button>

                </a>

            </div>



            <% if(requests.length === 0){ %>

                <div class="empty-box">

                    <h2>No Requests Yet</h2>

                    <p>
                        New chat requests will appear here
                    </p>

                </div>

            <% } %>



            <% requests.forEach((req)=>{ %>

                <div class="request-user-card">

                    <div class="request-left">

                        <div class="avatar">

                            <%= req.sender.charAt(0).toUpperCase() %>

                        </div>

                        <div class="user-info">

                            <h3>

                                <%= req.sender %>

                            </h3>

                            <span>

                                wants to chat with you

                            </span>

                        </div>

                    </div>



                    <div class="request-actions">

                        <form
                            action="/approve/<%= req.sender %>"
                            method="POST"
                        >

                            <button
                                type="submit"
                                class="approve-btn"
                            >

                                Approve

                            </button>

                        </form>



                        <form
                            action="/delete-request/<%= req.sender %>"
                            method="POST"
                        >

                            <button
                                type="submit"
                                class="delete-btn"
                            >

                                Delete

                            </button>

                        </form>

                    </div>

                </div>

            <% }) %>

        </div>

    </div>

</body>

</html>