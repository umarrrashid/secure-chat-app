<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Users</title>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial;
        }

        body{

            height:100vh;

            display:flex;

            justify-content:center;

            align-items:center;

            background:linear-gradient(
                135deg,
                #0f172a,
                #1e3a5f,
                #4c3f91
            );

        }

        .container{

            width:420px;

            padding:30px;

            border-radius:25px;

            background:rgba(255,255,255,0.1);

            backdrop-filter:blur(15px);

            color:white;

            box-shadow:0 8px 30px rgba(0,0,0,0.3);

        }

        h1{

            margin-bottom:10px;

        }

        p{

            color:#ddd;

            margin-bottom:20px;

        }

        .user{

            display:flex;

            justify-content:space-between;

            align-items:center;

            padding:15px;

            border-radius:18px;

            background:rgba(255,255,255,0.08);

            margin-bottom:15px;

        }

        .left{

            display:flex;

            align-items:center;

            gap:12px;

        }

        .avatar{

            width:45px;

            height:45px;

            border-radius:50%;

            background:#6d4aff;

            display:flex;

            justify-content:center;

            align-items:center;

            font-weight:bold;

            font-size:20px;

        }

        .name{

            font-size:20px;

            font-weight:bold;

        }

        .status{

            color:#00ff6a;

            font-size:14px;

        }

        .btn{

            padding:10px 18px;

            border:none;

            border-radius:12px;

            color:white;

            text-decoration:none;

            font-weight:bold;

        }

        .request{

            background:#ff9800;

        }

        .chat{

            background:#3b82f6;

        }

        .pending{

            background:gray;

        }

        .logout{

            display:block;

            text-align:center;

            margin-top:20px;

            padding:15px;

            border-radius:15px;

            background:#ff3131;

            color:white;

            text-decoration:none;

            font-weight:bold;

        }

    </style>

</head>

<body>

<div class="container">

    <h1>

        Welcome <%= currentUser %>

    </h1>

    <p>

        Select a user to start chatting

    </p>

    <% users.forEach((user) => { %>

        <div class="user">

            <div class="left">

                <div class="avatar">

                    <%= user.username.charAt(0).toUpperCase() %>

                </div>

                <div>

                    <div class="name">

                        <%= user.username %>

                    </div>

                    <div class="status">

                        ● Online

                    </div>

                </div>

            </div>

            <div>

                <%

                let request = requests.find(r =>

                    (r.from === currentUser &&
                     r.to === user.username)

                    ||

                    (r.from === user.username &&
                     r.to === currentUser)

                );

                %>

                <% if(!request){ %>

                    <a
                       class="btn request"
                       href="/request/<%= user.username %>">

                       Request

                    </a>

                <% } else if(request.status === "pending"){ %>

                    <button class="btn pending">

                        Pending

                    </button>

                <% } else if(request.status === "accepted"){ %>

                    <a
                       class="btn chat"
                       href="/chat/<%= user.username %>">

                       Chat

                    </a>

                <% } %>

            </div>

        </div>

    <% }) %>

    <a class="logout" href="/requests">

        Requests

    </a>

    <a class="logout" href="/logout">

        Logout

    </a>

</div>

</body>

</html>