<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Users</title>

    <link rel="stylesheet"
          href="/style.css">

</head>

<body>

    <div class="users-container">

        <h1>
            Welcome <%= currentUser %>
        </h1>

        <p>
            Select a user to start chatting
        </p>

        <% users.forEach(user => { %>

            <div class="user-card">

                <div class="user-left">

                    <div class="avatar">

                        <%= user.username.charAt(0).toUpperCase() %>

                    </div>

                    <div>

                        <h3>
                            <%= user.username %>
                        </h3>

                        <span class="online">
                            ● Online
                        </span>

                    </div>

                </div>

                <div>

                    <%

                    let relation = requests.find(r =>

                        (r.from === currentUser &&
                         r.to === user.username)

                        ||

                        (r.from === user.username &&
                         r.to === currentUser)

                    );

                    %>

                    <% if(!relation){ %>

                        <a href="/request/<%= user.username %>"
                           class="request-btn">

                            Request

                        </a>

                    <% } else if(relation.status === "pending"){ %>

                        <% if(relation.to === currentUser){ %>

                            <a href="/requests"
                               class="chat-btn">

                                Approve

                            </a>

                        <% } else { %>

                            <button class="pending-btn">

                                Pending

                            </button>

                        <% } %>

                    <% } else if(relation.status === "accepted"){ %>

                        <a href="/chat/<%= user.username %>"
                           class="chat-btn">

                            Chat

                        </a>

                    <% } %>

                </div>

            </div>

        <% }) %>

        <div class="bottom-buttons">

    <a href="/requests">

        <button class="requests-btn">

            Requests

        </button>

    </a>

    <a href="/logout">

        <button class="logout-btn">

            Logout

        </button>

    </a>

</div>

    </div>

</body>

</html>