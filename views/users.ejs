<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Users</title>

    <link rel="stylesheet"
          href="/style.css">

</head>

<body>

    <div class="users-container">

        <h1>
            Welcome <%= currentUser %>
        </h1>

        <p>
            Select a user to start chatting
        </p>



        <% users.forEach(user => { %>

            <div class="user-card">

                <!-- LEFT SIDE -->

                <div class="user-left">

                    <div class="avatar">

                        <%= user.username.charAt(0).toUpperCase() %>

                    </div>

                    <div>

                        <h3>
                            <%= user.username %>
                        </h3>

                        <span class="online">
                            ● Online
                        </span>

                    </div>

                </div>



                <!-- RIGHT SIDE -->

                <div>

                    <%

                    let relation = requests.find(r =>

                        (

                            r.sender === currentUser &&

                            r.receiver === user.username

                        )

                        ||

                        (

                            r.sender === user.username &&

                            r.receiver === currentUser

                        )

                    );

                    %>



                    <!-- NO REQUEST -->

                    <% if(!relation){ %>

                        <form
                            action="/request/<%= user.username %>"
                            method="POST"
                        >

                            <button
                                type="submit"
                                class="request-btn"
                            >

                                Request

                            </button>

                        </form>



                    <!-- PENDING -->

                    <% } else if(relation.status === "pending"){ %>



                        <!-- RECEIVED REQUEST -->

                        <% if(relation.receiver === currentUser){ %>

                            <a href="/requests"
                               class="chat-btn">

                                Approve

                            </a>

                        <% } else { %>

                            <button class="pending-btn">

                                Pending

                            </button>

                        <% } %>



                    <!-- ACCEPTED -->

                    <% } else if(relation.status === "accepted"){ %>

                        <a href="/chat/<%= user.username %>"
                           class="chat-btn">

                            Chat

                        </a>

                    <% } %>

                </div>

            </div>

        <% }) %>



        <!-- BOTTOM BUTTONS -->

        <div class="bottom-buttons">

            <a href="/requests">

                <button class="requests-btn">

                    Requests

                </button>

            </a>



            <a href="/logout">

                <button class="logout-btn">

                    Logout

                </button>

            </a>

        </div>

    </div>

</body>

</html>